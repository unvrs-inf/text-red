{
  "name": "docchat",
  "version": "0.1.0",
  "private": true,
  "main": "dist/electron/main.js",
  "scripts": {
    "copy:worker": "node -e \"require('fs').copyFileSync('node_modules/react-pdf/node_modules/pdfjs-dist/build/pdf.worker.min.mjs', 'public/pdf.worker.min.mjs')\"",
    "dev": "npm run copy:worker && next dev",
    "build": "npm run copy:worker && next build",
    "start": "next start",
    "lint": "eslint",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:compile": "tsc -p tsconfig.electron.json",
    "electron:copy": "node scripts/copy-standalone.js",
    "electron:build": "npm run build && npm run electron:compile && npm run electron:copy && electron-builder"
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "lucide-react": "^1.0.1",
    "mammoth": "^1.12.0",
    "next": "16.2.1",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "^5.5.207",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "react-pdf": "^10.4.1",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "concurrently": "^9.2.1",
    "electron": "^34.5.8",
    "electron-builder": "^25.1.8",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wait-on": "^8.0.5"
  }
}
